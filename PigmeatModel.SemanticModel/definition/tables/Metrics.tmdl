	measure 'Indicator weight' =
			
			
			VAR waga_wlk_importu = ROUND(Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * 'Weight3.2'[Weight3.2 Value], 4)
			VAR waga_luka = ROUND(Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * (1 - 'Weight3.2'[Weight3.2 Value]), 4)
			VAR waga_CAGR = ROUND(Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value]) * 'Weight3.1'[Weight3.1 Value], 4)
			VAR waga_PKB = ROUND(Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value]) * (1 - 'Weight3.1'[Weight3.1 Value]), 4)
			VAR waga_clo = ROUND((1 - Weight1[Weight1 Value]) * 'Weight2.2'[Weight2.2 Value], 4)
			VAR waga_dyst = ROUND((1 - Weight1[Weight1 Value]) * (1 - 'Weight2.2'[Weight2.2 Value]), 4)
			
			RETURN
			        SWITCH(
			            SELECTEDVALUE(Indicators[Indicator]),
			            "Import size",waga_wlk_importu,
			            "Import gap", waga_luka,
			            "CAGR", waga_CAGR,
			            "GDP forecast", waga_PKB,
			            "Tariff", waga_clo,
			            "Distance", waga_dyst,
			            BLANK()
			        )
		displayFolder: Indicator measures
		lineageTag: 888c85b7-fd8f-467f-8f27-5b597288ebb7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Indicator value normalized' =
			
			
			VAR import_size = [ImportSizeNormalized]
			VAR import_gap = [ImportGapNormalized]
			VAR CAGR = SUM(fact_pork_market_growth[import_CAGR_normalized])
			VAR GDP_forecast = SUM(fact_pork_market_growth[gdp_growth_forecast_normalized])
			VAR tariff = IF(ISBLANK(SUM(fact_trade_barriers[tariff_avg_normalized])), BLANK(), 1 - SUM(fact_trade_barriers[tariff_avg_normalized]))
			VAR distance = IF(ISBLANK(SUM(fact_trade_barriers[dist_normalized])), BLANK(), 1 - SUM(fact_trade_barriers[dist_normalized]))
			
			RETURN
			        SWITCH(
			            SELECTEDVALUE(Indicators[Indicator]),
			            "Import size", import_size,
			            "Import gap", import_gap,
			            "CAGR", CAGR,
			            "GDP forecast", GDP_forecast,
			            "Tariff", tariff,
			            "Distance", distance,
			            BLANK()
			        )
		displayFolder: Indicator measures
		lineageTag: 62c5d231-a684-49ce-aec9-30034c6009f0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Indicator weight * value' =
			
			
			VAR import_size = [ImportSizeNormalized]
			VAR import_gap = [ImportGapNormalized]
			VAR CAGR = SUM(fact_pork_market_growth[import_CAGR_normalized])
			VAR GDP_forecast = SUM(fact_pork_market_growth[gdp_growth_forecast_normalized])
			VAR tariff = IF(ISBLANK(SUM(fact_trade_barriers[tariff_avg_normalized])), BLANK(), 1 - SUM(fact_trade_barriers[tariff_avg_normalized]))
			VAR distance = IF(ISBLANK(SUM(fact_trade_barriers[dist_normalized])), BLANK(), 1 - SUM(fact_trade_barriers[dist_normalized]))
			
			VAR w_import_size = ROUND(Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * 'Weight3.2'[Weight3.2 Value], 4)
			VAR w_import_gap = ROUND(Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * (1 - 'Weight3.2'[Weight3.2 Value]), 4)
			VAR w_CAGR = ROUND(Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value]) * 'Weight3.1'[Weight3.1 Value], 4)
			VAR w_GDP_forecast = ROUND(Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value]) * (1 - 'Weight3.1'[Weight3.1 Value]), 4)
			VAR w_tariff = ROUND((1 - Weight1[Weight1 Value]) * 'Weight2.2'[Weight2.2 Value], 4)
			VAR w_dist = ROUND((1 - Weight1[Weight1 Value]) * (1 - 'Weight2.2'[Weight2.2 Value]), 4)
			
			
			RETURN
			        SWITCH(
			            SELECTEDVALUE(Indicators[Indicator]),
			            "Import size", w_import_size * import_size,
			            "Import gap", w_import_gap * import_gap,
			            "CAGR", w_CAGR * CAGR,
			            "GDP forecast", w_GDP_forecast * GDP_forecast,
			            "Tariff", w_tariff * tariff,
			            "Distance", w_dist * distance,
			            BLANK()
			        )
		displayFolder: Indicator measures
		lineageTag: 6f427842-8f2c-4e8c-ac3f-d1fb5cc6600e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ImportGap =
			
			
			VAR maxYear =
			    CALCULATE(
			        MAX(fact_pork_market[year]),
			        FILTER(
			            ALL(fact_pork_market),
			            NOT(ISBLANK(fact_pork_market[import_tonnes])) &&
			            NOT(ISBLANK(fact_pork_market[import_gap]))
			        )
			    )
			RETURN IF(
			    MAX(dim_partner[faostat_fallback]) = 1,
			    CALCULATE(MAX(fact_pork_market[import_gap]), fact_pork_market[year] = maxYear - 1),
			    CALCULATE(MAX(fact_pork_market[import_gap]), fact_pork_market[year] = maxYear))
		lineageTag: 96a6448a-bd8b-4085-9767-c7e0ae9c8aca

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ImportSize =
			
			VAR maxYear =
			    CALCULATE(
			        MAX(fact_pork_market[year]),
			        FILTER(
			            ALL(fact_pork_market),
			            NOT(ISBLANK(fact_pork_market[import_tonnes])) &&
			            NOT(ISBLANK(fact_pork_market[import_gap]))
			        )
			    )
			
			RETURN IF(
			    MAX(dim_partner[faostat_fallback]) = 1,
			    CALCULATE(MAX(fact_pork_market[import_tonnes]), fact_pork_market[year] = maxYear - 1),
			    CALCULATE(MAX(fact_pork_market[import_tonnes]), fact_pork_market[year] = maxYear))
		lineageTag: 95132868-eeb2-42c0-ac02-6fc1c03bf4c3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Indicator value' =
			
			
			VAR import_size = [ImportSize]
			VAR import_gap = [ImportGap]
			VAR CAGR = ROUND(SUM(fact_pork_market_growth[import_CAGR]),2)
			VAR GDP_forecast = ROUND(SUM(fact_pork_market_growth[gdp_forecast_growth_avg]),2)
			VAR tariff = ROUND(SUM(fact_trade_barriers[tariff_avg]), 2)
			VAR distance = SUM(fact_trade_barriers[dist])
			
			RETURN
			        SWITCH(
			            SELECTEDVALUE(Indicators[Indicator]),
			            "Import size", import_size & " tonnes",
			            "Import gap", import_gap & " tonnes",
			            "CAGR", CAGR * 100 & "%",
			            "GDP forecast", GDP_forecast & "%",
			            "Tariff", tariff * 100 & "%",
			            "Distance", distance & " km",
			            BLANK()
			        )
		displayFolder: Indicator measures
		lineageTag: 3ff291b9-819a-4c94-817a-ce252e7c9c29

	partition Metrics = m
		mode: import
		source =
