	measure 'Bariery handlowe' = "1 - (" & ROUND('Weight2.2'[Weight2.2 Value], 2) & " * Wielkość importu + " & ROUND((1-'Weight2.2'[Weight2.2 Value]), 2) & " * Luka importowa)"
		displayFolder: Measure Explenation
		lineageTag: cc9293b8-252d-4a8c-b476-03b37427517b

	measure 'Ocena rynku całość' = ```
			
			 
			
			 VAR waga_wlk_importu = ROUND(Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * 'Weight3.2'[Weight3.2 Value], 4)
			 VAR waga_luka = ROUND(Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * (1 - 'Weight3.2'[Weight3.2 Value]), 4)
			 VAR waga_CAGR = ROUND(Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value]) * 'Weight3.1'[Weight3.1 Value], 4)
			 VAR waga_PKB = ROUND(Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value]) * (1 - 'Weight3.1'[Weight3.1 Value]), 4)
			 VAR waga_clo = ROUND((1 - Weight1[Weight1 Value]) * 'Weight2.2'[Weight2.2 Value], 4)
			 VAR waga_dyst = ROUND((1 - Weight1[Weight1 Value]) * (1 - 'Weight2.2'[Weight2.2 Value]), 4)
			
			 Var waga_bariery = ROUND((1 - Weight1[Weight1 Value]), 4)
			
			 RETURN (waga_wlk_importu & " * Wielkość importu + " & waga_luka & " * Luka importowa + " & waga_CAGR & " * CAGR importu + " & waga_PKB & " * Prognoza PKB + " & waga_bariery & " - ( " & waga_clo & " * Cło importowe + " & waga_dyst & " * Dystans)")
			 
			```
		displayFolder: Measure Explenation
		lineageTag: dcee773d-9c82-4de5-81df-56132ac5658c

	measure 'Parameters value' =
			
			
			VAR waga_wlk_importu = ROUND(Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * 'Weight3.2'[Weight3.2 Value], 4)
			 VAR waga_luka = ROUND(Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * (1 - 'Weight3.2'[Weight3.2 Value]), 4)
			 VAR waga_CAGR = ROUND(Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value]) * 'Weight3.1'[Weight3.1 Value], 4)
			 VAR waga_PKB = ROUND(Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value]) * (1 - 'Weight3.1'[Weight3.1 Value]), 4)
			 VAR waga_clo = ROUND((1 - Weight1[Weight1 Value]) * 'Weight2.2'[Weight2.2 Value], 4)
			 VAR waga_dyst = ROUND((1 - Weight1[Weight1 Value]) * (1 - 'Weight2.2'[Weight2.2 Value]), 4)
			
			VAR P = SELECTEDVALUE('Parameters Hierarchy'[Parameter])
			RETURN
			    SWITCH(
			        P,
			        "Tariff", waga_clo,
			        "Distance", waga_dyst,
			        BLANK()
			    )
		lineageTag: 547ab938-3f35-44b9-8760-bb654650ae4d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Parameters value test' =
			
			
			VAR demand_weight = ROUND(Weight1[Weight1 Value], 4)
			VAR barriers_weight = ROUND((1 - Weight1[Weight1 Value]), 4)
			
			VAR trade_weight = ROUND(Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value], 4)
			VAR growth_weight = ROUND(Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value]), 4)
			
			
			VAR waga_wlk_importu = ROUND(Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * 'Weight3.2'[Weight3.2 Value], 4)
			VAR waga_luka = ROUND(Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * (1 - 'Weight3.2'[Weight3.2 Value]), 4)
			VAR waga_CAGR = ROUND(Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value]) * 'Weight3.1'[Weight3.1 Value], 4)
			VAR waga_PKB = ROUND(Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value]) * (1 - 'Weight3.1'[Weight3.1 Value]), 4)
			VAR waga_clo = ROUND((1 - Weight1[Weight1 Value]) * 'Weight2.2'[Weight2.2 Value], 4)
			VAR waga_dyst = ROUND((1 - Weight1[Weight1 Value]) * (1 - 'Weight2.2'[Weight2.2 Value]), 4)
			
			VAR P = SELECTEDVALUE('Parameters Hierarchy'[Parameter])
			RETURN
			  SWITCH(
			    TRUE(),
			
			    /* 🔹 PARAMETER level */
			    ISINSCOPE('Parameters Hierarchy'[Parameter]),
			        SWITCH(
			            SELECTEDVALUE('Parameters Hierarchy'[Parameter]),
			            "Import size",waga_wlk_importu,
			            "Import gap", waga_luka,
			            "CAGR", waga_CAGR,
			            "GDP forecast", waga_PKB,
			            BLANK()
			        ),
			
			    /* 🔹 GROUP lvl 2 */
			    ISINSCOPE('Parameters Hierarchy'[Group lvl 2]),
			        SWITCH(
			            SELECTEDVALUE('Parameters Hierarchy'[Group lvl 2]),
			            "Trade", trade_weight,
			            "Growth", growth_weight,
			            "Tariff", waga_clo,
			            "Distance", waga_dyst,
			            BLANK()
			        ),
			
			    /* 🔹 GROUP lvl 1 */
			    ISINSCOPE('Parameters Hierarchy'[Group lvl 1]),
			        SWITCH(
			            SELECTEDVALUE('Parameters Hierarchy'[Group lvl 1]),
			            "Demand", demand_weight,
			            "Barriers", barriers_weight,
			            BLANK()
			        )
			)
		lineageTag: fcdd6dc8-1348-4c05-b838-63624618090f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

