table Metrics
	lineageTag: 9b1e4f71-ea36-483e-a314-8b6db4c61183

	measure MinGap
		lineageTag: 11f4930f-2077-485c-b636-5b3d5f3c4ed5

		annotation 436ba87b-9c83-4389-a31b-ebd06a36be98 = {"Expression":null}

		annotation 277cc1b9-af89-4597-8e15-cacc25c0886b = To use special characters in a measure name, enclose the entire name in brackets ( [] ) and add a ] to any closing brackets in the name.

	measure MaxGap = ```
			
			
			VAR AnalisedYear = 2022
			
			VAR X = SUM(fact_pork_market[consumption_tones]) - SUM(fact_pork_market[production_tonnes])
			
			
			VAR XMax =
			    CALCULATE(
			        MAXX(
			            ALL(fact_pork_market[country_id]),
			            SUM(fact_pork_market[consumption_tones]) - SUM(fact_pork_market[production_tonnes])
			        ),
			        KEEPFILTERS(fact_pork_market[year] = AnalisedYear)      // filtr po roku
			    )
			    
			
			RETURN
			    XMax
			```
		lineageTag: 7db42d89-53e8-4314-9560-c7947e6980e0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Gap = CALCULATE(SUM(fact_pork_market[consumption_tones]) - SUM(fact_pork_market[production_tonnes]), fact_pork_market[year] = 2022)
		lineageTag: 0f88a0e7-e909-49f3-bd52-58d403245527

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure MarketScore = 0.2 * MAX(fact_pork_market_growth[import_CAGR_normalized]) + 0.2 * MAX(fact_pork_market_growth[gdp_growth_forecast_normalized]) + 0.05 *MAX(fact_trade_barriers[tariff_avg_normalized]) + 0.05 * MAX(fact_trade_barriers[dist_normalized]) + 0.25 * [ImportGapNormalized] + 0.25 * [ImportSizeNormalized]
		formatString: 0.0000
		lineageTag: a5b1edd8-adf1-415d-8882-7a234ebdab1c

	measure ImportSizeNormalized =
			
			VAR maxYear =
			    CALCULATE(
			        MAX(fact_pork_market[year]),
			        FILTER(
			            ALL(fact_pork_market),
			            NOT(ISBLANK(fact_pork_market[import_tonnes])) &&
			            NOT(ISBLANK(fact_pork_market[import_gap]))
			        )
			    )
			
			RETURN IF(
			    MAX(dim_partner[faostat_fallback]) = 1,
			    CALCULATE(MAX(fact_pork_market[import_size_normalized]), fact_pork_market[year] = maxYear - 1),
			    CALCULATE(MAX(fact_pork_market[import_size_normalized]), fact_pork_market[year] = maxYear))
		lineageTag: 3469d4d3-8696-455b-a17c-6ca248e8e164

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ImportGapNormalized =
			
			
			VAR maxYear =
			    CALCULATE(
			        MAX(fact_pork_market[year]),
			        FILTER(
			            ALL(fact_pork_market),
			            NOT(ISBLANK(fact_pork_market[import_tonnes])) &&
			            NOT(ISBLANK(fact_pork_market[import_gap]))
			        )
			    )
			
			RETURN IF(
			    MAX(dim_partner[faostat_fallback]) = 1,
			    CALCULATE(MAX(fact_pork_market[import_gap_normalized]), fact_pork_market[year] = maxYear - 1),
			    CALCULATE(MAX(fact_pork_market[import_gap_normalized]), fact_pork_market[year] = maxYear))
		lineageTag: c1a6a685-de04-4769-b592-617f03ef4f07

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '3.1 Growth Metric' = 'Weight3.1'[Weight3.1 Value] * MAX(fact_pork_market_growth[import_CAGR_normalized]) + (1 - 'Weight3.1'[Weight3.1 Value]) * MAX(fact_pork_market_growth[gdp_growth_forecast_normalized])
		lineageTag: 4d10522f-57d6-4010-9dc6-88ca76f68023

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '3.2 Market metric' = 'Weight3.2'[Weight3.2 Value] * [ImportSizeNormalized] + (1 - 'Weight3.2'[Weight3.2 Value]) * [ImportGapNormalized]
		lineageTag: a4c4f752-1d16-4c06-96d3-00861b29f78a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '2.1 Demand metric' = 'Weight2.1'[Weight2.1 Value] * [3.2 Market metric] + (1 - 'Weight2.1'[Weight2.1 Value]) * [3.1 Growth Metric]
		lineageTag: 37ee28f2-53e8-4d69-9721-811a7ee6cca2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '2.2 Ease metric' = ```
			
			
			VAR w_tariff = 'Weight2.2'[Weight2.2 Value]
			VAR w_dist = 1 - 'Weight2.2'[Weight2.2 Value]
			
			VAR tariff = MAX(fact_trade_barriers[tariff_avg_normalized])
			VAR dist = MAX(fact_trade_barriers[dist_normalized])
			
			RETURN 
			 SWITCH(
			    TRUE(),
			    AND(NOT(ISBLANK(tariff)), NOT(ISBLANK(dist))), 1 - (w_tariff * tariff + w_dist * dist),
			    AND(ISBLANK(tariff), ISBLANK(dist)), BLANK(),
			    OR(ISBLANK(tariff), ISBLANK(dist)), 0.5 - (w_tariff * tariff + w_dist * dist),
			    BLANK())
			```
		lineageTag: fd1bc494-c9f1-4dc8-9285-36d7c60a542e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1. MarketScore' = ROUND([Weight1 Value] * [2.1 Demand metric] + (1 - [Weight1 Value]) * [2.2 Ease metric], 4)
		lineageTag: 37b83112-c100-4b6a-a120-5924968b637e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Weights = ```
			"ImportSize: " & [ImportSizeWeight] & " ImportGap: " & [ImportGapWeight] & " CAGR: " & Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value])  * 'Weight3.1'[Weight3.1 Value] 
			& " GDP: " & Weight1[Weight1 Value] * (1 - 'Weight2.1'[Weight2.1 Value])  * ( 1 - 'Weight3.1'[Weight3.1 Value])
			& " Tariff: " & ROUND((1 - Weight1[Weight1 Value]) * 'Weight2.2'[Weight2.2 Value], 4) 
			& " Distance: " & ROUND((1 - Weight1[Weight1 Value]) * (1 - 'Weight2.2'[Weight2.2 Value]), 4)
			```
		lineageTag: 3ee5c707-fc58-4aeb-b2f2-62d290829c7c

	measure ImportSizeWeight = Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * 'Weight3.2'[Weight3.2 Value]
