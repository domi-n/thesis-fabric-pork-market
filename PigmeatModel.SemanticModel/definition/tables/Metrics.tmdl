		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ImportGapWeight = Weight1[Weight1 Value] * 'Weight2.1'[Weight2.1 Value] * ( 1 - 'Weight3.2'[Weight3.2 Value])
